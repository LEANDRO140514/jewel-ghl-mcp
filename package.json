{
  "name": "jewel-ghl-mcp",
  "version": "1.0.0",
  "description": "JEWEL GHL MCP Server 💎 — Claude construye, clona y despliega workflows, automatizaciones, snapshots, Meta Ads, landings, email marketing y encuestas de GoHighLevel en lenguaje natural.",
  "main": "dist/main.js",
  "bin": {
    "jewel-ghl-mcp": "dist/server.js",
    "jewel-ghl": "scripts/ghl-mcp.mjs"
  },
  "files": [
    "dist/",
    "scripts/",
    "docs/",
    "examples/",
    "mcp-apps/",
    "README.md",
    "package.json",
    ".env.example"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build:server": "node scripts/build-server.mjs",
    "build": "npm run build:server",
    "dev": "nodemon --exec ts-node src/main.ts",
    "start": "node dist/main.js",
    "start:stdio": "node dist/server.js",
    "start:http": "node dist/main.js",
    "start:legacy": "node dist/http-server.js",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "node scripts/build-server.mjs --check",
    "scan:ghl-api": "node scripts/scan-ghl-api-coverage.mjs --refresh && node scripts/generate-official-spec-tools.mjs && node scripts/scan-ghl-api-coverage.mjs && node scripts/classify-local-endpoints.mjs && npm run build && node scripts/ghl-mcp.mjs report",
    "ci:ghl-api-drift": "npm run scan:ghl-api && git diff --exit-code -- docs/GHL-API-COVERAGE-REPORT.md docs/GHL-LOCAL-ENDPOINT-CLASSIFICATION.md docs/ghl-api-coverage.json docs/API-DASHBOARD.md docs/tool-inventory.json src/tools/official-spec-tools.ts src/tools/official-spec-endpoints.json",
    "smoke:ghl-live": "node scripts/ghl-live-smoke.mjs",
    "tools:doctor": "node scripts/ghl-mcp.mjs doctor",
    "tools:list": "node scripts/ghl-mcp.mjs list-tools",
    "tools:report": "node scripts/ghl-mcp.mjs report",
    "tools:explorer": "node scripts/ghl-mcp.mjs explorer",
    "tools:configure": "node scripts/ghl-mcp.mjs configure claude",
    "tools:update-api": "node scripts/ghl-mcp.mjs update-api",
    "apps:install": "npm install --prefix mcp-apps",
    "apps:build": "npm run build --prefix mcp-apps",
    "apps:typecheck": "npm run typecheck --prefix mcp-apps",
    "apps:start:stdio": "npm run start:stdio --prefix mcp-apps",
    "apps:start:http": "npm run start:http --prefix mcp-apps"
  },
  "keywords": [
    "mcp",
    "jewel-ghl",
    "gohighlevel",
    "workflows",
    "snapshots",
    "automatizaciones",
    "meta-ads",
    "landing-pages",
    "email-marketing",
    "encuestas",
    "claude"
  ],
  "author": "LEANDRO140514",
  "license": "ISC",
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.29",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0"
  }
}
