# ================================================
# JEWEL GHL MCP Server — Configuración de entorno
# ================================================

# ==================== GO HIGH LEVEL ====================
# Private Integration Token (PIT) - El más importante
# Crea uno en tu cuenta GHL → Settings → API Keys → Private Integration
GHL_API_KEY=your_private_integration_api_key_here

# Location ID (obligatorio para la mayoría de operaciones)
GHL_LOCATION_ID=your_location_id_here

# Base URL oficial de GHL (no cambiar)
GHL_BASE_URL=https://services.leadconnectorhq.com

# Versión de la API (actual al 2026)
GHL_API_VERSION=2021-07-28

# ==================== SERVIDOR MCP ====================
# Puerto para modo HTTP (opcional, solo si usas start:http)
PORT=3000

# Modo de desarrollo (true = logs más detallados)
NODE_ENV=development

# ==================== JEWEL GHL (configuración futura) ====================
# Estos valores se usarán cuando armemos el SaaS multi-tenant
# Por ahora déjalos comentados

# JWT_SECRET=super_secret_key_for_jewel_ghl
# SUPABASE_URL=your_supabase_url
# SUPABASE_ANON_KEY=your_supabase_anon_key

# ================================================
# INSTRUCCIONES:
# 1. Copia este archivo a .env
# 2. Reemplaza los valores con tus credenciales reales de GHL
# 3. Nunca subas tu .env a GitHub (ya está en .gitignore)
# ================================================
